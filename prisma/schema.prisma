generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id            Int      @id @default(autoincrement())
  address       String
  propertyType  String
  status        String   @default("New")
  createdAt     DateTime @default(now())
}
